  "reproduction": {
    "outer_cv": {
      "n_splits": 5,
      "shuffle": true,
      "random_state": 42
    },
    "inner_cv": {
      "n_splits": 3,
      "shuffle": true,
      "random_state": 42
    },
    "threshold_grid": {
      "start": 0.05,
      "stop": 0.95,
      "step": 0.01
    },
    "logistic_c_grid": [
      0.0005,
      0.001,
      0.005,
      0.01,
      0.02,
      0.05,
      0.1,
      0.2,
      0.5,
      1.0,
      5.0
    ],
    "lambda_ranking": {
      "c": 0.05,
      "max_iter": 2000,
      "solver": "liblinear",
      "class_weight": "balanced",
      "random_state": 42
    },
    "experiments": [
      {
        "experiment_id": "hq_only",
        "title": "HQ only",
        "feature_bank_ids": [
