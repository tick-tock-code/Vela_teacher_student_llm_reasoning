{
  "experiment_id": "teacher_student_distillation_v1",
  "description": "Reasoning-reconstruction pipeline for predicting selected policy targets from reusable VCBench intermediary feature banks.",
  "datasets": {
    "public_train_csv": "data/VCBench_data/vcbench_final_public.csv",
    "private_test_csv": "data/VCBench_data/vcbench_final_private (success column removed) - vcbench_final_private.csv"
  },
  "reasoning_target_bank": {
    "train_path": "data/reasoning_feature_targets/policy_features.csv",
    "test_path": "data/reasoning_feature_targets/policy_features_test.csv",
    "source_id_column": "uuid",
    "target_id_column": "founder_uuid",
    "target_regex": "^Policy_\\d+$",
    "scale_min": 0.0,
    "scale_max": 1.0,
    "prediction_mode": "regression"
  },
  "reasoning_targets": [
    {
      "target_id": "Policy_36"
    },
    {
      "target_id": "Policy_16"
    },
    {
      "target_id": "Policy_5"
    },
    {
      "target_id": "Policy_30"
    },
    {
      "target_id": "Policy_45"
    },
    {
      "target_id": "Policy_4"
    },
    {
      "target_id": "Policy_26"
    },
    {
      "target_id": "Policy_18"
    },
    {
      "target_id": "Policy_7"
    },
    {
      "target_id": "Policy_35"
    }
  ],
  "reasoning_models": [
    {
      "model_id": "ridge",
      "kind": "ridge"
    },
    {
      "model_id": "xgb1_regressor",
      "kind": "xgb1_regressor"
    }
  ],
  "intermediary_features": [
    {
      "feature_id": "mirror",
      "kind": "vcbench_mirror_baseline_v1",
      "enabled": true
    },
    {
      "feature_id": "sentence_prose",
      "kind": "sentence_transformer_prose_v1",
      "enabled": true,
      "embedding_model_name": "sentence-transformers/all-MiniLM-L6-v2"
    },
    {
      "feature_id": "sentence_structured",
      "kind": "sentence_transformer_structured_v1",
      "enabled": true,
      "embedding_model_name": "sentence-transformers/all-MiniLM-L6-v2"
    },
    {
      "feature_id": "llm_engineered",
      "kind": "llm_engineered_v1",
      "enabled": false
    }
  ],
  "feature_sets": [
    {
      "feature_set_id": "mirror",
      "feature_ids": ["mirror"]
    },
    {
      "feature_set_id": "sentence_prose",
      "feature_ids": ["sentence_prose"]
    },
    {
      "feature_set_id": "sentence_structured",
      "feature_ids": ["sentence_structured"]
    },
    {
      "feature_set_id": "sentence_prose_plus_structured",
      "feature_ids": ["sentence_prose", "sentence_structured"]
    },
    {
      "feature_set_id": "mirror_plus_sentence_prose_plus_structured",
      "feature_ids": ["mirror", "sentence_prose", "sentence_structured"]
    }
  ],
  "cv": {
    "n_splits": 3,
    "shuffle": true,
    "random_state": 42
  }
}
