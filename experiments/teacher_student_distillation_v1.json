{
  "experiment_id": "teacher_student_distillation_v1",
  "description": "Teacher-student regression pipeline for predicting policy reasoning targets from raw founder inputs.",
  "datasets": {
    "public_train_csv": "data/VCBench_data/vcbench_final_public.csv",
    "private_test_csv": "data/VCBench_data/vcbench_final_private (success column removed) - vcbench_final_private.csv"
  },
  "input_features": {
    "kind": "founder_baseline_v1"
  },
  "reasoning_target_bank": {
    "train_path": "data/reasoning_feature_targets/policy_features.csv",
    "test_path": "data/reasoning_feature_targets/policy_features_test.csv",
    "source_id_column": "uuid",
    "target_id_column": "founder_uuid",
    "target_regex": "^Policy_\\d+$",
    "scale_min": 0.0,
    "scale_max": 1.0,
    "prediction_mode": "regression"
  },
  "reasoning_targets": [
    {
      "target_id": "Policy_36"
    },
    {
      "target_id": "Policy_16"
    },
    {
      "target_id": "Policy_5"
    },
    {
      "target_id": "Policy_30"
    },
    {
      "target_id": "Policy_45"
    },
    {
      "target_id": "Policy_4"
    },
    {
      "target_id": "Policy_26"
    },
    {
      "target_id": "Policy_18"
    },
    {
      "target_id": "Policy_7"
    },
    {
      "target_id": "Policy_35"
    }
  ],
  "reasoning_models": [
    {
      "model_id": "ridge",
      "kind": "ridge"
    },
    {
      "model_id": "xgb1_regressor",
      "kind": "xgb1_regressor"
    }
  ],
  "downstream_models": [
    {
      "model_id": "lr_classifier",
      "kind": "lr_classifier"
    },
    {
      "model_id": "xgb1_classifier",
      "kind": "xgb1_classifier"
    }
  ],
  "cv": {
    "n_splits": 3,
    "shuffle": true,
    "random_state": 42
  },
  "promotion": {
    "mode": "manual",
    "approved": false
  }
