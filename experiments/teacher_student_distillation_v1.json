{
  "experiment_id": "teacher_student_distillation_v1",
  "description": "Feature Repository integration with default benchmark reproduction mode and reasoning-distillation mode for v25 and Taste policy targets.",
  "datasets": {
    "public_train_csv": "data/VCBench_data/vcbench_final_public.csv",
    "private_test_csv": "data/VCBench_data/vcbench_final_private (success column removed) - vcbench_final_private.csv"
  },
  "feature_repository": {
    "root_dir": "Feature Repository",
    "labels_path": "Feature Repository/splits/labels.csv",
    "train_uuids_path": "Feature Repository/splits/train_uuids.txt",
    "test_uuids_path": "Feature Repository/splits/test_uuids.txt"
  },
  "defaults": {
    "run_mode": "reproduction_mode",
    "target_family": "v25_policies",
    "heldout_evaluation": false
  },
  "repository_feature_banks": [
    {
      "feature_bank_id": "hq_baseline",
      "train_path": "Feature Repository/hq_baseline/features_train.csv",
      "test_path": "Feature Repository/hq_baseline/features_test.csv",
      "source_id_column": "founder_uuid",
      "enabled": true,
      "feature_prefixes": [],
      "exclude_columns": [],
      "label_column": "success",
      "all_features_binary": false,
      "binary_feature_columns": [
        "has_prior_ipo",
        "has_prior_acquisition",
        "stem_flag",
        "seniority_is_monotone",
        "company_size_is_growing",
        "industry_alignment",
        "is_serial_founder"
      ]
    },
    {
      "feature_bank_id": "llm_engineering",
      "train_path": "Feature Repository/llm_engineering/features_train.csv",
      "test_path": "Feature Repository/llm_engineering/features_test.csv",
      "source_id_column": "founder_uuid",
      "enabled": true,
      "feature_prefixes": [
        "le_"
      ],
      "exclude_columns": [],
      "label_column": null,
      "all_features_binary": true,
      "binary_feature_columns": []
    },
    {
      "feature_bank_id": "lambda_policies",
      "train_path": "Feature Repository/lambda_policies/predictions_train.csv",
      "test_path": "Feature Repository/lambda_policies/predictions_test.csv",
      "source_id_column": "founder_uuid",
      "enabled": true,
      "feature_prefixes": [
        "lam_"
      ],
      "exclude_columns": [],
      "label_column": null,
      "all_features_binary": true,
      "binary_feature_columns": []
    },
    {
      "feature_bank_id": "policy_v25",
      "train_path": "Feature Repository/policies/predictions_train.csv",
      "test_path": "Feature Repository/policies/predictions_test.csv",
      "source_id_column": "founder_uuid",
      "enabled": false,
      "feature_prefixes": [
        "v25_"
      ],
      "exclude_columns": [],
      "label_column": null,
      "all_features_binary": false,
      "binary_feature_columns": []
    }
  ],
  "intermediary_features": [
    {
      "feature_bank_id": "sentence_prose",
